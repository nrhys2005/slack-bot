# 프로젝트별 설정
# name: Slack에서 입력할 프로젝트명 (키는 자유롭게 지정 가능)
# path: 프로젝트 루트 경로 (claude CLI 실행 위치)
# commands: 허용할 명령어 목록
# wiki: true면 @멘션 질문 시 Notion MCP 검색용 프로젝트로 사용 (1개만)
# db_backend: true면 /db 커맨드에서 DB 모델·자격증명 소스로 사용 (1개만)
#   - {path}/app/.env 에서 POSTGRESQL_* 환경변수를 읽어 psql 접속에 사용
#   - DB 유저는 DB 레벨에서 read-only 권한을 가진 계정을 쓰는 것을 강력히 권장

projects:
  my-project:
    path: /path/to/my-project
    commands:
      - harness
      - plan
      - develop
      - review

  my-wiki:
    path: /path/to/my-wiki
    commands: []
    wiki: true

  # FastAPI 백엔드 — DB 모델과 .env(자격증명) 소스
  # projects.yaml 키 이름은 자유 (예: ra-backend, my_backend). 디렉토리명과 달라도 됨.
  my-backend:
    path: /path/to/my_backend
    commands: []
    db_backend: true
