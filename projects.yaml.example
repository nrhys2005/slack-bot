# 프로젝트별 설정
# name: Slack에서 입력할 프로젝트명
# path: 프로젝트 루트 경로 (claude CLI 실행 위치)
# commands: 허용할 명령어 목록
# wiki: true면 @멘션 질문 시 Notion MCP 검색용 프로젝트로 사용 (1개만)

projects:
  my-project:
    path: /path/to/my-project
    commands:
      - harness
      - plan
      - develop
      - review

  my-wiki:
    path: /path/to/my-wiki
    commands: []
    wiki: true
